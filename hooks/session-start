#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# event-io.sh: pure function definitions, no source-time side effects. A
# genuinely un-opted repo gets ZERO directory creation from sourcing alone
# (spec §4.3). state-io.sh is GONE (calibration wave T4 = the v4.2 deletion
# calendar): the v3.7 migration chain, legacy state readers, and
# grandfathering all died with their era — `.claude/cortex/enabled` written
# by /cortex:setup is the ONLY opt-in path.
source "$SCRIPT_DIR/scripts/lib/event-io.sh" || { printf '{}'; exit 0; }
source "$SCRIPT_DIR/scripts/lib/health-trend.sh" || { printf '{}'; exit 0; }

# Buffer stdin to extract session_id
HOOK_INPUT=$(cat)

# --- Opt-in gate (spec §4.3): the sentinel FILE, before any other work ---
[ -f "$(_eio_cortex_dir)/enabled" ] || { printf '{}'; exit 0; }

source "$SCRIPT_DIR/scripts/lib/escape-json.sh" || { printf '{}'; exit 0; }
source "$SCRIPT_DIR/scripts/lib/housekeeping.sh" || true

# Path constants — via event-io helpers (state-io's source-time variable
# block died with it in T4).
PROJECT_DIR="$(eio_project_dir)"
HEALTH_FILE="$(eio_health_file)"
PROPOSALS_FILE="$(eio_proposals_file)"

# Extract session_id from hook JSON (Claude Code provides this)
HOOK_SESSION_ID=""
if [ -n "$HOOK_INPUT" ]; then
  # || true inside each substitution: jq/python3 exit non-zero on malformed JSON,
  # and under set -euo pipefail a failing assignment kills the whole hook (contract
  # violation: session-start always exits 0 with JSON). Mirrors resolve_event_log.
  if command -v jq >/dev/null 2>&1; then
    HOOK_SESSION_ID=$(echo "$HOOK_INPUT" | jq -r '.session_id // empty' 2>/dev/null || true)
  fi
  if [ -z "$HOOK_SESSION_ID" ] && command -v python3 >/dev/null 2>&1; then
    HOOK_SESSION_ID=$(echo "$HOOK_INPUT" | python3 -c "import sys,json; print(json.load(sys.stdin).get('session_id',''))" 2>/dev/null || true)
  fi
  if [ -z "$HOOK_SESSION_ID" ]; then
    # POSIX-awk match() + first-line-first-match: tolerates pretty-printed
    # JSON (spaces/newlines around ":") and prefers the FIRST occurrence of a
    # duplicated key. No jq/python3 dependency — this tier must stand alone
    # (Codex I-3). Mirrors event-io.sh's resolve_event_log.
    HOOK_SESSION_ID=$(printf '%s' "$HOOK_INPUT" | awk '
      match($0, /"session_id"[[:space:]]*:[[:space:]]*"[^"]*"/) {
        s = substr($0, RSTART, RLENGTH)
        sub(/^"session_id"[[:space:]]*:[[:space:]]*"/, "", s)
        sub(/"$/, "", s)
        print s
        exit
      }
    ' 2>/dev/null) || true
  fi
fi
# Reject any sid that could become more than one path component. event-io's
# extractor applies the same guard for every append-only hook; session-start
# mirrors it here because this hook extracts inline and creates the log.
HOOK_SESSION_ID=$(_eio_sanitize_sid "$HOOK_SESSION_ID")
# Fallback: epoch + PID if no session_id from Claude Code. The `-$$` suffix makes
# concurrent boots in the same second collision-resistant (distinct log files).
[ -z "$HOOK_SESSION_ID" ] && HOOK_SESSION_ID="$(date +%s)-$$"

# (The native-hooks.ok marker is DELETED — calibration wave T5. It proved
# native registration to dispatchers so they could suppress bootstrap-era
# settings.json double-fires; T4 verified that era's entries are gone and
# removed the machinery. No shared mutable identity file replaces it.)

# --- Create the per-session event log (the ONLY place it is created) ---
# Line format: epoch|session_start|<iso8601-utc> <model_name>. The first value
# token is a HARD contract: stop-gate Gate 6 parses it as the git --since anchor.
# model_name is "unknown" at boot (matches v3's model_name=unknown default).
# printf (not append_event) because the file does not exist yet.
mkdir -p "$(_eio_week_dir)" 2>/dev/null || true
EVENT_LOG="$(_eio_week_dir)/${HOOK_SESSION_ID}.events.log"
# No-clobber: never truncate an existing log (a resumed session with the same id
# keeps its prior events). Only create — and seed the session_start anchor — when
# the file does not yet exist. Degraded mode (write fails) must not abort the hook.
EVENT_LOG_CREATED=false
if [ ! -f "$EVENT_LOG" ]; then
  printf '%s|session_start|%s %s\n' "$(date +%s)" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "unknown" > "$EVENT_LOG" 2>/dev/null || true
  [ -f "$EVENT_LOG" ] && EVENT_LOG_CREATED=true
fi

# (current-session.id is DELETED — calibration wave T5, queue item 6: a
# shared mutable singleton cannot survive multi-actor reality — a guest boot
# clobbered it twice in one week, misattributing reads and nearly routing a
# health row to the wrong log. The sid now travels EXPLICITLY: injected into
# the boot context below, re-injected by pre-compact, passed as an argument
# by the session-end skill and /cortex:status. No sid ⇒ surfaces degrade to
# "unavailable" — never a guess.)

# Condition drives every adaptive-tier gate below (calibration wave T6,
# queue item 9): "core" = control (record / carry-over / blocking gates
# ONLY), "lab" = core + the frozen adaptive tier. eio_get_profile maps the
# legacy profile names.
PROFILE=$(eio_get_profile)

# --- Provenance stamp (T6; vocabulary addition, docs/state-files.md §3.3):
# one per log, appended at creation — condition, plugin version, repo, host.
# Model/harness version are NOT in the hook payload; the experiment protocol
# assigns those fields to the per-session journal header (split schema).
if [ "${EVENT_LOG_CREATED:-false}" = true ]; then
  _plugin_version=$(sed -n 's/.*"version": "\([^"]*\)".*/\1/p' "${PLUGIN_ROOT}/.claude-plugin/plugin.json" 2>/dev/null | head -1) || true
  append_event "provenance" "condition=${PROFILE} plugin=${_plugin_version:-unknown} repo=$(basename "$(eio_project_dir)") host=$(uname -s 2>/dev/null || echo unknown)"
fi

# --- Step 0b: Housekeeping (calibration wave, queue item 7: the healer is
# DELETED — instrument-defect verdict, it never repaired damage it or its
# sibling writer didn't cause. health.local.md is create-once + append-only
# now. What survives is the hygiene with a clean record: temp/backup cleanup
# + week-dir pruning, silent — no "self-repair" reporting.) ---
if type cortex_housekeeping &>/dev/null; then
  cortex_housekeeping 2>/dev/null || true
fi

# --- Step 1: Derive carry-over from prior sessions ---
# Sole source: prior append-only event logs (the legacy *.local.md reader and
# bootstrap-hooks.sh cleanup call died in T4 with state-io — settings.json
# verified clean of hook entries at deletion time, see the T4 commit).
# Surviving items are re-appended into the NEW log so per-session derivations
# (stop-gate Gate 4, pre-compact hash reconcile) stay single-log.
old_carry_over=""

# Event logs: collect the 30-day-recent prior logs (mtime filter; skip the
# log we just created), then let the shared eio_unresolved_items helper compute
# the epoch-ordered unresolved set GLOBALLY across all of them (spec §3.5
# amendment: latest carry_over epoch anywhere vs latest carry_addressed epoch
# anywhere — an item addressed in a DIFFERENT log still reconciles, and one
# re-raised after addressing resurfaces). Per-log (items, age) are stashed so the
# age max can be computed AFTER the global unresolved set is known — a log's age
# only counts if at least one of ITS items is in that set (else a fully-addressed
# stale log would bleed its age onto fresh items and false-block stop-gate Gate 5).
declare -a _scanned_logs=()
declare -a _elog_items=()
declare -a _elog_age=()
cutoff_epoch=$(date -d "30 days ago" +%s 2>/dev/null || date -v-30d +%s 2>/dev/null || echo "0")
for f in "$(_eio_sessions_dir)"/*/*.events.log; do
  [ -f "$f" ] || continue
  [ "$f" = "$EVENT_LOG" ] && continue  # never scan the log we just created
  if [ "$cutoff_epoch" -gt 0 ]; then
    f_epoch=$(stat -c %Y "$f" 2>/dev/null || stat -f %m "$f" 2>/dev/null || echo "0")
    if [ "$f_epoch" -gt 0 ] && [ "$f_epoch" -lt "$cutoff_epoch" ]; then
      continue
    fi
  fi
  _scanned_logs+=("$f")
  _elog_items+=("$(list_events carry_over "$f")")
  age=$(last_event carry_over_age "$f")
  age="${age:-0}"
  case "$age" in *[!0-9]*) age=0 ;; esac
  _elog_age+=("$age")
done

# Global epoch-ordered unresolved set across all scanned prior logs.
event_unresolved=""
if [ "${#_scanned_logs[@]}" -gt 0 ]; then
  event_unresolved=$(eio_unresolved_items "${_scanned_logs[@]}")
fi
if [ -n "$event_unresolved" ]; then
  old_carry_over="${old_carry_over}${event_unresolved}"$'\n'
fi

# Precompute the unresolved items' hashes once for the survival loop below.
# Membership MUST compare hashes, not raw text: eio_item_hash trims whitespace
# precisely because LLM-typed carry-over drifts — the same logical item can be
# carried whitespace-padded in one log and trimmed in another (hash-equal,
# text-unequal), and eio_unresolved_items dedups by hash keeping only the
# FIRST-SEEN text variant. A raw-text check would miss the padded variant and
# drop that log's age from the max (crediting e.g. 2 instead of 7).
event_unresolved_hashes=""
if [ -n "$event_unresolved" ]; then
  while IFS= read -r _uit; do
    [ -z "$_uit" ] && continue
    event_unresolved_hashes="${event_unresolved_hashes}$(eio_item_hash "$_uit")"$'\n'
  done <<< "$event_unresolved"
fi

# Age max, second pass: include a log's age ONLY if at least one of its own
# carry_over items' hashes is in the global unresolved set (per-log survival
# against the global reconciliation).
event_carry_age="0"
_elog_n=${#_elog_age[@]}
_elog_i=0
while [ "$_elog_i" -lt "$_elog_n" ]; do
  _li="${_elog_items[$_elog_i]}"
  _la="${_elog_age[$_elog_i]}"
  _survives=0
  if [ -n "$_li" ] && [ -n "$event_unresolved_hashes" ]; then
    while IFS= read -r _it; do
      [ -z "$_it" ] && continue
      _ih=$(eio_item_hash "$_it")
      if printf '%s' "$event_unresolved_hashes" | grep -qxF "$_ih"; then
        _survives=1
        break
      fi
    done <<< "$_li"
  fi
  if [ "$_survives" -eq 1 ] && [ "$_la" -gt "$event_carry_age" ]; then
    event_carry_age="$_la"
  fi
  _elog_i=$((_elog_i + 1))
done

# Filter merged carry-over: only keep lines that look like actual items (not raw
# journal content). Valid: "- ", "* ", "TODO", "[carry-over]", "[mid-session pin]".
if [ -n "$old_carry_over" ]; then
  old_carry_over=$(echo "$old_carry_over" | grep -E '^[-*] |^TODO|^\[carry-over\]|^\[mid-session pin\]' | sort -u | sed '/^$/d' || true)
fi

# Max carry-over age across prior event logs (per-log survival max above).
old_carry_over_age="$event_carry_age"

# Re-append surviving carry-over into the NEW log + record the age event.
# Same semantics as v3: increment age if carry-over persists, else reset to 0.
if [ -n "$old_carry_over" ]; then
  while IFS= read -r co_item; do
    [ -z "$co_item" ] && continue
    append_event "carry_over" "$co_item"
  done <<< "$old_carry_over"
  append_event "carry_over_age" "$(( old_carry_over_age + 1 ))"
else
  append_event "carry_over_age" "0"
fi

# --- Step 1b: Synthesis automation (LAB-only — the adaptive tier IS the
# treatment; a core boot must not read or rewrite collaboration.md) ---
COLLAB_FILE="${HOME}/.cortex/synthesis/collaboration.md"
synthesis_actions=""
if [ "$PROFILE" = "lab" ] && [ -f "$COLLAB_FILE" ]; then
  export COLLAB_FILE
  synthesis_actions=$("$SCRIPT_DIR/scripts/synthesis-automation.sh" 2>/dev/null || echo "")
fi

# --- Step 3: Compact session-start pulse (context diet, spec §10/R6) ---
# Condition-split (T6, Codex plan-review C-1/audit finding 4): the CORE pulse
# carries an explicit condition line and NO collaboration/synthesis
# instructions — even a manually invoked skill is told to skip them. Ambient
# memory (MEMORY.md, journal, lessons.md) stays in BOTH conditions: Core
# isolates the plugin's adaptive machinery, not the maintainer's memory
# (four-memory confound, documented limitation).
if [ "$PROFILE" = "core" ]; then
  skill_content="Session id: ${HOOK_SESSION_ID} — when a skill needs to write session events (session-end ritual, carry_addressed), pass this EXACT id as the argument; if it is no longer in context, SKIP the write and say so — never guess a session id.

Condition: core — control condition. The adaptive tier is OFF this session: do NOT read ~/.cortex/synthesis/ files, run synthesis tasks, or apply collaboration patterns, even if a skill instructs it.

## Session-start protocol (core)
1. Read MEMORY.md, then read-or-create memory/$(date +%Y-%m-%d).md; write any carry-over surfaced below into it as the first entry.
2. Display the statusline line above verbatim, plus a model-metadata line: 🤖 {model} · ⚡ {effort} · 🪟 {context window}.
3. Non-trivial task: scan tasks/lessons.md by domain. Touching architecture/schema/pipeline: check documentation.md staleness first."
else
  skill_content="Session id: ${HOOK_SESSION_ID} — when a skill needs to write session events (session-end ritual, carry_addressed), pass this EXACT id as the argument; if it is no longer in context, SKIP the write and say so — never guess a session id.

Condition: lab

## Session-start protocol (compact pulse — full protocol: /cortex:session-start)
1. Read MEMORY.md, then read-or-create memory/$(date +%Y-%m-%d).md; write any carry-over surfaced below into it as the first entry. If a missed session-end warning appears below, run /cortex:session-end retrospectively first.
2. Read ~/.cortex/synthesis/collaboration.md (full file) and ~/.cortex/synthesis/workflows/_index.md; complete the REQUIRED synthesis tasks listed above before addressing the user's message.
3. Display the statusline lines above verbatim, plus a model-metadata line: 🤖 {model} · ⚡ {effort} · 🪟 {context window}.
4. Non-trivial task: scan tasks/lessons.md by domain and log surfaced lesson IDs (L-YYYYMMDD-nn) to the journal. Touching architecture/schema/pipeline: check documentation.md staleness first.
5. Housekeeping (after greeting, non-blocking): archive previous-month journals with no open [carry-over]; clean .claude/cortex .tmp files.
When in doubt, invoke /cortex:session-start for the full skill."
fi

yesterday=$(date -d "yesterday" +%Y-%m-%d 2>/dev/null \
  || date -v-1d +%Y-%m-%d 2>/dev/null || echo "")
missed_close=""
if [[ -n "$yesterday" ]]; then
  yjournal="${PROJECT_DIR}/memory/${yesterday}.md"
  if [[ -f "$yjournal" ]]; then
    ycontent=$(cat "$yjournal" 2>/dev/null || echo "")
    if [[ "$ycontent" != *"[session-end]"* && "$ycontent" != *"[carry-over]"* && "$ycontent" != *"session end"* ]]; then
      missed_close=$'\n\n'"Yesterday's session-end was not run. Consider running /cortex:session-end now."
    fi
  fi
fi

# --- Step 4b: Feedback Loop — compute behavioral flags (v2: git-derived
# medians only, spec §6.2). v3's Step 4 narrative health_warning block (avg
# reasoning-misses / avg edits-per-commit / trend_direction header messaging)
# and the churn/avg_epc-driven mode paths below it are GONE — those header
# fields no longer exist (self-report demoted; trend is computed at READ time
# from v2 rows via health-trend.sh, never stored). Cautious mode now triggers
# ONLY from the fix_ratio/rework_files medians below; commit_nudge_threshold
# has no v2 data source anymore, so it's a flat default.
fb_mode="normal"
fb_reason="boot"
fb_commit_threshold=15

if [ "$PROFILE" = "lab" ] && [ -f "$HEALTH_FILE" ]; then
  ht_result=$(ht_trend "$HEALTH_FILE")
  IFS='|' read -r _ht_total _ht_nonidle ht_verdict ht_reason <<< "$ht_result"
  if [ "$ht_verdict" = "degrading" ]; then
    fb_mode="cautious"
    fb_reason="$ht_reason"
  fi
fi
# Core: mode_set stays appended (derivation stability for readers) but is
# always "normal boot" — cautious-mode is treatment.
append_event "mode_set" "$fb_mode $fb_reason"
append_event "threshold_set" "$fb_commit_threshold"

# --- Step 4c: Statusline ---
statusline_output=""
if [ -f "$SCRIPT_DIR/scripts/statusline.sh" ]; then
  statusline_output=$("$SCRIPT_DIR/scripts/statusline.sh" "$HOOK_INPUT" 2>/dev/null || echo "")
fi

# --- Step 5: Proposal surfacing — RETIRED with the "strict" profile name
# (T6): proposal review is a maintainer act, not treatment. The pending
# queue rides in proposals.local.md until post-verdict, reviewed via
# /analyze-session; the surfaced_count rewrite went with it (one less
# document writer at boot).
proposal_summary=""

# --- Step 5b: Social System — cross-session patterns (LAB-only) ---
social_warnings=""

if [ "$PROFILE" = "lab" ] && [ -f "$HEALTH_FILE" ]; then
  # Get last 5 data rows (skip headers/metadata). `|| true`: the grep -v chain
  # empties out (exit 1) on a header-only file; pipefail would otherwise abort.
  social_data=$(grep -v '^#' "$HEALTH_FILE" 2>/dev/null | grep -v '^$' | grep -v '^trend_' | grep -v '^avg_' | grep -v '^---' | grep '|' | tail -5 || true)
  social_row_count=0
  if [ -n "$social_data" ]; then
    social_row_count=$(echo "$social_data" | wc -l | tr -d ' ')
  fi

  if [ "${social_row_count:-0}" -ge 3 ]; then
    # Domain clustering. Health rows are a MIX of v2 (field 13 = domain) and
    # legacy (field 12 = domain_tag) shapes — a plain "$12" would silently
    # read v2's `topology` field instead (bug introduced by the v2 schema
    # change; fixed here by branching on the v2 sentinel, field 1).
    recent_domains=$(echo "$social_data" | awk -F'|' '
      $1 == "v2" && $13 != "" { print $13; next }
      $1 != "v2" && NF >= 12 && $12 != "" { print $12 }
    ')
    if [ -n "$recent_domains" ]; then
      top_domain_line=$(echo "$recent_domains" | sort | uniq -c | sort -rn | head -1 | sed 's/^[[:space:]]*//')
      domain_count=$(echo "$top_domain_line" | awk '{print $1}')
      domain_name=$(echo "$top_domain_line" | awk '{print $2}')
      if [ "${domain_count:-0}" -ge 3 ] && [ "$domain_name" != "mixed" ] && [ "$domain_name" != "idle" ]; then
        social_warnings="${social_warnings}You've been working on ${domain_name} for ${domain_count} of the last 5 sessions. Consider: is the approach working, or circling?"$'\n'
      fi
    fi

    # Session length trend. duration_min is field 9 on legacy rows but field
    # 10 on v2 rows — same v2-sentinel branch as above.
    recent_durations=$(echo "$social_data" | awk -F'|' '
      $1 == "v2" { print $10; next }
      { print $9 }
    ')
    if [ -n "$recent_durations" ]; then
      avg_dur=$(echo "$recent_durations" | awk '{s+=$1; c++} END {if(c>0) printf "%d", s/c; else print 0}')
      if [ "${avg_dur:-0}" -lt 5 ] && [ "${avg_dur:-0}" -gt 0 ]; then
        social_warnings="${social_warnings}Last 5 sessions averaged ${avg_dur} minutes. Longer focused sessions may be more productive."$'\n'
      fi
    fi
  fi
fi

# Recurring file edits — derived at read from the week-bucket logs (wave 5,
# locked D6). LAB-only (T6): cross-session adaptive display is treatment —
# it previously rode OUTSIDE the profile gate, which the emitter census
# caught. Protocol is count|path (count first): the path is everything after
# the FIRST pipe — paths may themselves contain pipes (W5 review I-3).
if [ "$PROFILE" = "lab" ]; then
  hot_files=$(eio_hot_files 30 4 | awk '{ i = index($0, "|"); if (i == 0) next; printf "  - %s (%s sessions)\n", substr($0, i + 1), substr($0, 1, i - 1) }')
  if [ -n "$hot_files" ]; then
    social_warnings="${social_warnings}Frequently edited files (4+ sessions):"$'\n'"${hot_files}"$'\n'"Consider if these need a deeper refactor."$'\n'
  fi
fi

# --- Step 5c: Sensory System — external awareness (LAB-only) ---
sensory_output=""
if [ "$PROFILE" = "lab" ] && [ -x "$SCRIPT_DIR/scripts/sensory-check.sh" ]; then
  # Pass HOOK_INPUT so sensory-check resolves its write-log from session_id
  # (full-scan signature: sensory-check.sh [--mid-session] [hook_json]).
  sensory_output=$("$SCRIPT_DIR/scripts/sensory-check.sh" "$HOOK_INPUT" 2>/dev/null || echo "")
fi

# --- Step 5d: Intervention follow-through report (spec §6.3, every 10th
# session). Cadence: number of PRIOR session logs in the 30-day scan window
# (Step 1's _scanned_logs — excludes the log just created) is a positive
# multiple of 10. The report itself is the same 30-day derivation /status
# and the statusline read; kinds with >=10 fires and <20% follow-through are
# surfaced as retirement candidates (user decides — never auto-retired).
intervention_report_msg=""
_prior_log_count=${#_scanned_logs[@]}
if [ "$PROFILE" = "lab" ] && [ "$_prior_log_count" -gt 0 ] && [ $((_prior_log_count % 10)) -eq 0 ]; then
  _ir=$(eio_intervention_report 2>/dev/null || true)
  if [ -n "$_ir" ]; then
    # WAVE-4 TUNABLE: retirement candidate = >=10 fires AND <20% follow-through
    RETIRE_MIN_FIRES=10
    RETIRE_MAX_PCT=20
    intervention_report_msg=$(printf '%s\n' "$_ir" | RMF="$RETIRE_MIN_FIRES" RMP="$RETIRE_MAX_PCT" awk -F'|' '
      {
        lines = lines "  " $1 ": " $3 "/" $2 " followed\n"
        if ($2 + 0 >= ENVIRON["RMF"] + 0 && $3 * 100 < $2 * (ENVIRON["RMP"] + 0)) {
          cand = cand (cand == "" ? "" : ", ") $1
        }
      }
      END {
        if (lines != "") {
          printf "Intervention follow-through (last 30 days):\n%s", lines
          if (cand != "") {
            printf "Retirement candidate(s) (>=%s fired, <%s%% followed): %s - consider retiring this nudge or adjusting its threshold.\n", ENVIRON["RMF"], ENVIRON["RMP"], cand
          }
        }
      }
    ')
  fi
fi

# --- Step 6: Carry-over re-injection ---
carry_over_msg=""
if [ -n "$old_carry_over" ]; then
  carry_over_msg=$'\n\n'"Carry-over from prior session:"$'\n'"${old_carry_over}"
fi

# --- Step 6b: Synthesis directive (judgment tasks for Claude) ---
synthesis_directive=""
if [ -f "$COLLAB_FILE" ]; then
  synthesis_directive="## REQUIRED: Synthesis Tasks (complete before responding to user)
${synthesis_actions:+
Hook automated:
${synthesis_actions}}
Claude MUST complete these (requires judgment):
- [ ] Applied tracking: Which collaboration patterns from collaboration.md are relevant to today's task? Write to today's journal.
- [ ] Duplicate detection: Any semantically similar entries in collaboration.md? Flag to user.

Do NOT skip these. Do NOT defer. Complete before addressing user's message."
fi

# --- Output ---
full_context="${statusline_output:+${statusline_output}$'\n\n'}${synthesis_directive:+${synthesis_directive}$'\n\n'}${skill_content}${missed_close}${proposal_summary}${social_warnings:+$'\n\n'${social_warnings}}${intervention_report_msg:+$'\n\n'${intervention_report_msg}}${sensory_output:+$'\n\n'Sensory scan:$'\n'${sensory_output}}${carry_over_msg}"
escaped=$(escape_for_json "$full_context")
context="<cortex-session-start>${escaped}</cortex-session-start>"

cat <<EOF
{
  "additional_context": "${context}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${context}"
  }
}
EOF
exit 0
