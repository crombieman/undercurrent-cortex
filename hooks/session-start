#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# event-io.sh sourced first: pure function definitions, no source-time side
# effects (unlike state-io.sh's migrate_state_files(), which does mkdir -p on
# .claude/cortex/ unconditionally when sourced, unless already migrated).
# Deferred below until AFTER the opt-in gate passes, so a genuinely un-opted
# repo gets ZERO directory creation from sourcing alone (spec §4.3).
source "$SCRIPT_DIR/scripts/lib/event-io.sh" || { printf '{}'; exit 0; }

# Buffer stdin to extract session_id
HOOK_INPUT=$(cat)

# --- Opt-in grandfathering (read-only probe) + gate (spec §4.3) ---
# Runs before state-io.sh is sourced (its migrate_state_files() side effect
# must never fire in a genuinely un-opted repo) and before any other work.
# Grandfathering: a project with REAL prior use (health.local.md carrying
# >=1 DATA row after the "---" separator — proof it predates opt-in gating,
# not a drive-by repo where .claude/cortex/ exists only as an old
# migrate_state_files side effect) gets the sentinel auto-created once.
# Everything else requires running /cortex:setup.
if [ ! -f "$(_eio_cortex_dir)/enabled" ]; then
  _gf_health_file="$(_eio_cortex_dir)/health.local.md"
  if [ -f "$_gf_health_file" ]; then
    _gf_health_data=$(sed -n '/^---$/,$p' "$_gf_health_file" 2>/dev/null | tail -n +2)
    if [ -n "$_gf_health_data" ] && printf '%s\n' "$_gf_health_data" | grep -q '|' 2>/dev/null; then
      mkdir -p "$(_eio_cortex_dir)" 2>/dev/null || true
      printf 'enabled %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" > "$(_eio_cortex_dir)/enabled" 2>/dev/null || true
    fi
  fi
fi
[ -f "$(_eio_cortex_dir)/enabled" ] || { printf '{}'; exit 0; }

# session-start is the SINGLE sanctioned exception still allowed to source
# state-io.sh (legacy carry-over reader + cleanup_stale_state_files /
# validate_organism, until Task 4.2 slims it). event-io.sh (sourced above) is
# the write path: this hook is the SOLE creator of the per-session
# append-only event log.
source "$SCRIPT_DIR/scripts/lib/state-io.sh" || { printf '{}'; exit 0; }
source "$SCRIPT_DIR/scripts/lib/escape-json.sh" || { printf '{}'; exit 0; }
source "$SCRIPT_DIR/scripts/lib/validate-organism.sh" || true

# Extract session_id from hook JSON (Claude Code provides this)
HOOK_SESSION_ID=""
if [ -n "$HOOK_INPUT" ]; then
  # || true inside each substitution: jq/python3 exit non-zero on malformed JSON,
  # and under set -euo pipefail a failing assignment kills the whole hook (contract
  # violation: session-start always exits 0 with JSON). Mirrors resolve_event_log.
  if command -v jq >/dev/null 2>&1; then
    HOOK_SESSION_ID=$(echo "$HOOK_INPUT" | jq -r '.session_id // empty' 2>/dev/null || true)
  fi
  if [ -z "$HOOK_SESSION_ID" ] && command -v python3 >/dev/null 2>&1; then
    HOOK_SESSION_ID=$(echo "$HOOK_INPUT" | python3 -c "import sys,json; print(json.load(sys.stdin).get('session_id',''))" 2>/dev/null || true)
  fi
  if [ -z "$HOOK_SESSION_ID" ]; then
    # POSIX-awk match() + first-line-first-match: tolerates pretty-printed
    # JSON (spaces/newlines around ":") and prefers the FIRST occurrence of a
    # duplicated key. No jq/python3 dependency — this tier must stand alone
    # (Codex I-3). Mirrors event-io.sh's resolve_event_log.
    HOOK_SESSION_ID=$(printf '%s' "$HOOK_INPUT" | awk '
      match($0, /"session_id"[[:space:]]*:[[:space:]]*"[^"]*"/) {
        s = substr($0, RSTART, RLENGTH)
        sub(/^"session_id"[[:space:]]*:[[:space:]]*"/, "", s)
        sub(/"$/, "", s)
        print s
        exit
      }
    ' 2>/dev/null) || true
  fi
fi
# Fallback: epoch + PID if no session_id from Claude Code. The `-$$` suffix makes
# concurrent boots in the same second collision-resistant (distinct log files).
[ -z "$HOOK_SESSION_ID" ] && HOOK_SESSION_ID="$(date +%s)-$$"

# --- Create the per-session event log (the ONLY place it is created) ---
# Line format: epoch|session_start|<iso8601-utc> <model_name>. The first value
# token is a HARD contract: stop-gate Gate 6 parses it as the git --since anchor.
# model_name is "unknown" at boot (matches v3's model_name=unknown default).
# printf (not append_event) because the file does not exist yet.
mkdir -p "$(_eio_week_dir)" 2>/dev/null || true
EVENT_LOG="$(_eio_week_dir)/${HOOK_SESSION_ID}.events.log"
# No-clobber: never truncate an existing log (a resumed session with the same id
# keeps its prior events). Only create — and seed the session_start anchor — when
# the file does not yet exist. Degraded mode (write fails) must not abort the hook.
if [ ! -f "$EVENT_LOG" ]; then
  printf '%s|session_start|%s %s\n' "$(date +%s)" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "unknown" > "$EVENT_LOG" 2>/dev/null || true
fi

# Write current session_id to a known location so the session-end skill
# can pass it to session-end-dispatch.sh, and read surfaces (statusline,
# sensory mid-session) can resolve when their hook JSON lacks a session_id.
mkdir -p "$CORTEX_DIR" 2>/dev/null || true
echo "$HOOK_SESSION_ID" > "${CORTEX_DIR}/current-session.id" 2>/dev/null || true

# Profile drives proposals/social/sensory/feedback gating below.
PROFILE=$(get_profile)

# --- Step 0: Cleanup stale state files (>24 hours old) ---
cleanup_stale_state_files

# --- Step 0b: Organism self-repair ---
repair_report=""
if type validate_organism &>/dev/null; then
  repair_result=$(validate_organism 2>/dev/null || echo "0|0|")
  repair_issues=$(echo "$repair_result" | cut -d'|' -f1)
  repair_fixes=$(echo "$repair_result" | cut -d'|' -f2)
  repair_details=$(echo "$repair_result" | cut -d'|' -f3-)
  if [ "${repair_issues:-0}" -gt 0 ]; then
    repair_report="Organism self-repair: fixed ${repair_fixes} of ${repair_issues} issues (${repair_details})"
  fi
fi

# --- Step 0c: Bootstrap PreToolUse/PostToolUse command hooks ---
# WORKAROUND: Plugin hooks.json command hooks silently dropped for PreToolUse/PostToolUse
# See: https://github.com/anthropics/claude-code/issues/34573
# Remove this when the bug is fixed.
PLUGIN_ROOT="$PLUGIN_ROOT" "$SCRIPT_DIR/scripts/bootstrap-hooks.sh" 2>/dev/null || true

# --- Step 1: Derive carry-over from prior sessions ---
# Two sources merged: (a) legacy *.local.md state files (state-io read path —
# session-start is the last reader of legacy state until Task 4.2) and (b) prior
# append-only event logs. Surviving items are re-appended into the NEW log so
# per-session derivations (stop-gate Gate 4, pre-compact hash reconcile) stay
# single-log.

# (a) Legacy: scan old state files' [carry_over] sections. Track the max
# carry_over_age among files that actually carried items (v3 semantics).
old_carry_over=""
legacy_carry_age="0"
for sf in "${SESSIONS_DIR}"/*/*.local.md "${STATE_DIR}"/cortex-state-*.local.md; do
  [ -f "$sf" ] || continue
  co=$(read_section "carry_over" "$sf")
  if [ -n "$co" ]; then
    old_carry_over="${old_carry_over}${co}"$'\n'
    age=$(read_field "carry_over_age" "$sf")
    age="${age:-0}"
    case "$age" in *[!0-9]*) age=0 ;; esac
    if [ "$age" -gt "$legacy_carry_age" ]; then
      legacy_carry_age="$age"
    fi
  fi
done

# (b) Event logs: collect the 30-day-recent prior logs (mtime filter; skip the
# log we just created), then let the shared eio_unresolved_items helper compute
# the epoch-ordered unresolved set GLOBALLY across all of them (spec §3.5
# amendment: latest carry_over epoch anywhere vs latest carry_addressed epoch
# anywhere — an item addressed in a DIFFERENT log still reconciles, and one
# re-raised after addressing resurfaces). Per-log (items, age) are stashed so the
# age max can be computed AFTER the global unresolved set is known — a log's age
# only counts if at least one of ITS items is in that set (else a fully-addressed
# stale log would bleed its age onto fresh items and false-block stop-gate Gate 5).
declare -a _scanned_logs=()
declare -a _elog_items=()
declare -a _elog_age=()
cutoff_epoch=$(date -d "30 days ago" +%s 2>/dev/null || date -v-30d +%s 2>/dev/null || echo "0")
for f in "$(_eio_sessions_dir)"/*/*.events.log; do
  [ -f "$f" ] || continue
  [ "$f" = "$EVENT_LOG" ] && continue  # never scan the log we just created
  if [ "$cutoff_epoch" -gt 0 ]; then
    f_epoch=$(stat -c %Y "$f" 2>/dev/null || stat -f %m "$f" 2>/dev/null || echo "0")
    if [ "$f_epoch" -gt 0 ] && [ "$f_epoch" -lt "$cutoff_epoch" ]; then
      continue
    fi
  fi
  _scanned_logs+=("$f")
  _elog_items+=("$(list_events carry_over "$f")")
  age=$(last_event carry_over_age "$f")
  age="${age:-0}"
  case "$age" in *[!0-9]*) age=0 ;; esac
  _elog_age+=("$age")
done

# Global epoch-ordered unresolved set across all scanned prior logs.
event_unresolved=""
if [ "${#_scanned_logs[@]}" -gt 0 ]; then
  event_unresolved=$(eio_unresolved_items "${_scanned_logs[@]}")
fi
if [ -n "$event_unresolved" ]; then
  old_carry_over="${old_carry_over}${event_unresolved}"$'\n'
fi

# Precompute the unresolved items' hashes once for the survival loop below.
# Membership MUST compare hashes, not raw text: eio_item_hash trims whitespace
# precisely because LLM-typed carry-over drifts — the same logical item can be
# carried whitespace-padded in one log and trimmed in another (hash-equal,
# text-unequal), and eio_unresolved_items dedups by hash keeping only the
# FIRST-SEEN text variant. A raw-text check would miss the padded variant and
# drop that log's age from the max (crediting e.g. 2 instead of 7).
event_unresolved_hashes=""
if [ -n "$event_unresolved" ]; then
  while IFS= read -r _uit; do
    [ -z "$_uit" ] && continue
    event_unresolved_hashes="${event_unresolved_hashes}$(eio_item_hash "$_uit")"$'\n'
  done <<< "$event_unresolved"
fi

# Age max, second pass: include a log's age ONLY if at least one of its own
# carry_over items' hashes is in the global unresolved set (per-log survival
# against the global reconciliation).
event_carry_age="0"
_elog_n=${#_elog_age[@]}
_elog_i=0
while [ "$_elog_i" -lt "$_elog_n" ]; do
  _li="${_elog_items[$_elog_i]}"
  _la="${_elog_age[$_elog_i]}"
  _survives=0
  if [ -n "$_li" ] && [ -n "$event_unresolved_hashes" ]; then
    while IFS= read -r _it; do
      [ -z "$_it" ] && continue
      _ih=$(eio_item_hash "$_it")
      if printf '%s' "$event_unresolved_hashes" | grep -qxF "$_ih"; then
        _survives=1
        break
      fi
    done <<< "$_li"
  fi
  if [ "$_survives" -eq 1 ] && [ "$_la" -gt "$event_carry_age" ]; then
    event_carry_age="$_la"
  fi
  _elog_i=$((_elog_i + 1))
done

# Filter merged carry-over: only keep lines that look like actual items (not raw
# journal content). Valid: "- ", "* ", "TODO", "[carry-over]", "[mid-session pin]".
if [ -n "$old_carry_over" ]; then
  old_carry_over=$(echo "$old_carry_over" | grep -E '^[-*] |^TODO|^\[carry-over\]|^\[mid-session pin\]' | sort -u | sed '/^$/d' || true)
fi

# Max carry-over age across all prior sources (legacy state files + event logs).
old_carry_over_age="$legacy_carry_age"
if [ "$event_carry_age" -gt "$old_carry_over_age" ]; then
  old_carry_over_age="$event_carry_age"
fi

# Re-append surviving carry-over into the NEW log + record the age event.
# Same semantics as v3: increment age if carry-over persists, else reset to 0.
if [ -n "$old_carry_over" ]; then
  while IFS= read -r co_item; do
    [ -z "$co_item" ] && continue
    append_event "carry_over" "$co_item"
  done <<< "$old_carry_over"
  append_event "carry_over_age" "$(( old_carry_over_age + 1 ))"
else
  append_event "carry_over_age" "0"
fi

# --- Step 1b: Synthesis automation (mechanical tasks) ---
# Promotion sweep + staleness check run in synthesis-automation.sh.
# Applied tracking + duplicate detection remain Claude's job (require judgment).
COLLAB_FILE="${HOME}/.cortex/synthesis/collaboration.md"
synthesis_actions=""
if [ -f "$COLLAB_FILE" ]; then
  export COLLAB_FILE
  synthesis_actions=$("$SCRIPT_DIR/scripts/synthesis-automation.sh" 2>/dev/null || echo "")
fi

# --- Step 3: Read skill content + yesterday check (preserved from v1) ---
skill_content=$(cat "${PLUGIN_ROOT}/skills/session-start/SKILL.md" 2>/dev/null \
  || echo "session-start skill not found")

yesterday=$(date -d "yesterday" +%Y-%m-%d 2>/dev/null \
  || date -v-1d +%Y-%m-%d 2>/dev/null || echo "")
missed_close=""
if [[ -n "$yesterday" ]]; then
  yjournal="${PROJECT_DIR}/memory/${yesterday}.md"
  if [[ -f "$yjournal" ]]; then
    ycontent=$(cat "$yjournal" 2>/dev/null || echo "")
    if [[ "$ycontent" != *"[session-end]"* && "$ycontent" != *"[carry-over]"* && "$ycontent" != *"session end"* ]]; then
      missed_close=$'\n\n'"Yesterday's session-end was not run. Consider running /cortex:session-end now."
    fi
  fi
fi

# --- Step 4: Operational intelligence (health trends) ---
health_warning=""
if [ -f "$HEALTH_FILE" ]; then
  # Read pre-computed rolling averages from header
  # `|| true` inside each substitution: grep exits 1 when the header line is
  # absent (header-only or partial health file); under pipefail that would kill
  # the hook. Empty result falls back to the ${:-default} at the use site.
  h_avg_rm=$(grep '^avg_reasoning_misses=' "$HEALTH_FILE" 2>/dev/null | cut -d= -f2 | tr -d '\r' || true)
  h_avg_epc=$(grep '^avg_edits_per_commit=' "$HEALTH_FILE" 2>/dev/null | cut -d= -f2 | tr -d '\r' || true)
  h_trend=$(grep '^trend_direction=' "$HEALTH_FILE" 2>/dev/null | cut -d= -f2 | tr -d '\r' || true)
  h_data_count=0
  if grep -v '^#' "$HEALTH_FILE" 2>/dev/null | grep -v '^$' | grep -v '^trend_' | grep -v '^avg_' | grep -v '^---' | grep -q '|' 2>/dev/null; then
    h_data_count=$(grep -v '^#' "$HEALTH_FILE" 2>/dev/null | grep -v '^$' | grep -v '^trend_' | grep -v '^avg_' | grep -v '^---' | grep -c '|')
  fi
  if [ "${h_data_count:-0}" -ge 1 ]; then
    health_warning="Session health (last 10): ${h_avg_rm:-0.0} avg misses, ${h_avg_epc:-0.0} avg edits/commit, trend: ${h_trend:-stable}"
  fi

  # Read last 3 data lines (skip comments and blanks)
  recent=$(grep -v '^#' "$HEALTH_FILE" 2>/dev/null | grep -v '^$' | grep '|' | tail -3 || echo "")
  # Check for rising reasoning_misses (field 2, pipe-delimited)
  if [ -n "$recent" ]; then
    high_miss_count=$(echo "$recent" | awk -F'|' '$2 > 0 {c++} END {print c+0}' | tr -d ' \r')
    if [ "${high_miss_count:-0}" -ge 2 ]; then
      health_warning="${health_warning}"$'\n'"Health: reasoning-misses elevated in recent sessions. Review lessons before touching domain code."
    fi
  fi

  # Trend direction check
  trend=$(grep '^trend_direction=' "$HEALTH_FILE" 2>/dev/null | cut -d= -f2 | tr -d '\r' || true)
  if [ "$trend" = "degrading" ]; then
    health_warning="${health_warning}"$'\n'"Health: DEGRADING trend detected. reasoning-misses increasing. Slow down and plan more carefully."
  fi

  # Commit granularity check
  avg_epc=$(grep '^avg_edits_per_commit=' "$HEALTH_FILE" 2>/dev/null | cut -d= -f2 | tr -d '\r' || true)
  if [ -n "$avg_epc" ]; then
    high_epc=$(awk "BEGIN { print ($avg_epc > 15.0) }")
    if [ "$high_epc" = "1" ]; then
      health_warning="${health_warning}"$'\n'"Health: avg edits/commit is ${avg_epc}. Commit more frequently — smaller, atomic commits."
    fi
  fi
fi

# --- Step 4b: Feedback Loop — compute behavioral flags ---
# v3 wrote mode/commit_nudge_threshold into the state file; v4 records them as
# events. mode_set value = "<mode> <reason>" (reason: trend|churn|boot) — the
# first token is what context-flow reads. Same health-file heuristics as v3.
fb_mode="normal"
fb_reason="boot"
fb_commit_threshold=15

if [ "$PROFILE" != "minimal" ] && [ -f "$HEALTH_FILE" ]; then
  fb_trend=$(grep '^trend_direction=' "$HEALTH_FILE" 2>/dev/null | cut -d= -f2 | tr -d '\r' || true)

  # Trend-based mode
  if [ "$fb_trend" = "degrading" ]; then
    fb_mode="cautious"
    fb_reason="trend"
  fi

  # Topology-based mode: last 3 data rows all high-churn.
  # `|| true`: the grep -v chain empties out (exit 1) on a header-only file; under
  # pipefail the unguarded assignment would kill the hook. Empty => 0 rows below.
  fb_data_rows=$(grep -v '^#' "$HEALTH_FILE" 2>/dev/null | grep -v '^$' | grep -v '^trend_' | grep -v '^avg_' | grep -v '^---' | grep '|' | tail -3 || true)
  fb_row_count=0
  if echo "$fb_data_rows" | grep -q '|' 2>/dev/null; then
    fb_row_count=$(echo "$fb_data_rows" | grep -c '|')
  fi
  if [ "${fb_row_count:-0}" -ge 3 ]; then
    fb_churn_count=$(echo "$fb_data_rows" | awk -F'|' '$11 == "high-churn" {c++} END {print c+0}')
    if [ "${fb_churn_count:-0}" -ge 3 ]; then
      fb_mode="cautious"
      [ "$fb_reason" = "boot" ] && fb_reason="churn"
    fi
  fi

  # Commit threshold adjustment
  fb_avg_epc=$(grep '^avg_edits_per_commit=' "$HEALTH_FILE" 2>/dev/null | cut -d= -f2 | tr -d '\r' || true)
  if [ -n "$fb_avg_epc" ]; then
    fb_high25=$(awk "BEGIN { print ($fb_avg_epc > 25.0) }" 2>/dev/null || echo "0")
    fb_high15=$(awk "BEGIN { print ($fb_avg_epc > 15.0) }" 2>/dev/null || echo "0")
    if [ "$fb_high25" = "1" ]; then
      fb_commit_threshold=5
    elif [ "$fb_high15" = "1" ]; then
      fb_commit_threshold=8
    fi
  fi
fi

append_event "mode_set" "$fb_mode $fb_reason"
append_event "threshold_set" "$fb_commit_threshold"

# --- Step 4c: Statusline ---
statusline_output=""
if [ -f "$SCRIPT_DIR/scripts/statusline.sh" ]; then
  statusline_output=$("$SCRIPT_DIR/scripts/statusline.sh" "$HOOK_INPUT" 2>/dev/null || echo "")
fi

# --- Step 5: Proposal surfacing (strict profile only) ---
proposal_summary=""
if [ "$PROFILE" = "strict" ] && [ -f "$PROPOSALS_FILE" ]; then
  pending_count=0
  if grep -q '^status=pending' "$PROPOSALS_FILE" 2>/dev/null; then
    pending_count=$(grep -c '^status=pending' "$PROPOSALS_FILE" 2>/dev/null)
  fi
  if [ "$pending_count" -gt 0 ]; then
    # Find oldest pending proposal date (id=YYYYMMDD-... comes before status=pending)
    oldest_date=""
    last_id=""
    while IFS= read -r line; do
      case "$line" in
        id=*) last_id=$(echo "$line" | sed 's/^id=\([0-9]\{8\}\).*/\1/') ;;
        status=pending)
          if [ -n "$last_id" ]; then
            if [ -z "$oldest_date" ] || [ "$last_id" \< "$oldest_date" ]; then
              oldest_date="$last_id"
            fi
          fi
          ;;
      esac
    done < "$PROPOSALS_FILE"

    age_info=""
    if [ -n "$oldest_date" ]; then
      oldest_fmt="${oldest_date:0:4}-${oldest_date:4:2}-${oldest_date:6:2}"
      oldest_epoch=$(date -d "$oldest_fmt" +%s 2>/dev/null || echo "0")
      if [ "$oldest_epoch" -gt 0 ]; then
        now_epoch=$(date +%s)
        age_days=$(( (now_epoch - oldest_epoch) / 86400 ))
        age_info=" (oldest: ${age_days}d)"
      fi
    fi

    proposal_summary=$'\n'"${pending_count} pending evolution proposal(s)${age_info}. Review with /analyze-session or say 'approve proposal'/'reject proposal'."

    # Increment surfaced_count for all pending proposals
    awk '
      /^status=pending/ { pending=1 }
      /^surfaced_count=/ && pending {
        val = substr($0, index($0,"=")+1) + 1
        print "surfaced_count=" val
        pending = 0
        next
      }
      /^---/ { pending=0 }
      { print }
    ' "$PROPOSALS_FILE" > "$PROPOSALS_FILE.tmp.$$" && mv "$PROPOSALS_FILE.tmp.$$" "$PROPOSALS_FILE"
  fi
fi

# --- Step 5b: Social System — cross-session patterns ---
social_warnings=""

if [ "$PROFILE" != "minimal" ] && [ -f "$HEALTH_FILE" ]; then
  # Get last 5 data rows (skip headers/metadata). `|| true`: the grep -v chain
  # empties out (exit 1) on a header-only file; pipefail would otherwise abort.
  social_data=$(grep -v '^#' "$HEALTH_FILE" 2>/dev/null | grep -v '^$' | grep -v '^trend_' | grep -v '^avg_' | grep -v '^---' | grep '|' | tail -5 || true)
  social_row_count=0
  if [ -n "$social_data" ]; then
    social_row_count=$(echo "$social_data" | wc -l | tr -d ' ')
  fi

  if [ "${social_row_count:-0}" -ge 3 ]; then
    # Domain clustering (field 12, may be empty on old rows)
    recent_domains=$(echo "$social_data" | awk -F'|' 'NF >= 12 && $12 != "" {print $12}')
    if [ -n "$recent_domains" ]; then
      top_domain_line=$(echo "$recent_domains" | sort | uniq -c | sort -rn | head -1 | sed 's/^[[:space:]]*//')
      domain_count=$(echo "$top_domain_line" | awk '{print $1}')
      domain_name=$(echo "$top_domain_line" | awk '{print $2}')
      if [ "${domain_count:-0}" -ge 3 ] && [ "$domain_name" != "mixed" ] && [ "$domain_name" != "idle" ]; then
        social_warnings="${social_warnings}You've been working on ${domain_name} for ${domain_count} of the last 5 sessions. Consider: is the approach working, or circling?"$'\n'
      fi
    fi

    # Session length trend
    recent_durations=$(echo "$social_data" | awk -F'|' '{print $9}')
    if [ -n "$recent_durations" ]; then
      avg_dur=$(echo "$recent_durations" | awk '{s+=$1; c++} END {if(c>0) printf "%d", s/c; else print 0}')
      if [ "${avg_dur:-0}" -lt 5 ] && [ "${avg_dur:-0}" -gt 0 ]; then
        social_warnings="${social_warnings}Last 5 sessions averaged ${avg_dur} minutes. Longer focused sessions may be more productive."$'\n'
      fi
    fi
  fi
fi

# Recurring file edits (from cross-session tracker)
CROSS_FILE="${CORTEX_DIR}/cross-session.local.md"
if [ -f "$CROSS_FILE" ]; then
  hot_files=$(awk -F'|' '/^[^#]/ && $2+0 >= 4 { printf "  - %s (%s sessions)\n", $1, $2 }' "$CROSS_FILE")
  if [ -n "$hot_files" ]; then
    social_warnings="${social_warnings}Frequently edited files (4+ sessions):"$'\n'"${hot_files}"$'\n'"Consider if these need a deeper refactor."$'\n'
  fi
fi

# --- Step 5c: Sensory System — external awareness ---
sensory_output=""
if [ "$PROFILE" != "minimal" ] && [ -x "$SCRIPT_DIR/scripts/sensory-check.sh" ]; then
  # Pass HOOK_INPUT so sensory-check resolves its write-log from session_id
  # (full-scan signature: sensory-check.sh [--mid-session] [hook_json]).
  sensory_output=$("$SCRIPT_DIR/scripts/sensory-check.sh" "$HOOK_INPUT" 2>/dev/null || echo "")
fi

# --- Step 6: Carry-over re-injection ---
carry_over_msg=""
if [ -n "$old_carry_over" ]; then
  carry_over_msg=$'\n\n'"Carry-over from prior session:"$'\n'"${old_carry_over}"
fi

# --- Step 6b: Synthesis directive (judgment tasks for Claude) ---
synthesis_directive=""
if [ -f "$COLLAB_FILE" ]; then
  synthesis_directive="## REQUIRED: Synthesis Tasks (complete before responding to user)
${synthesis_actions:+
Hook automated:
${synthesis_actions}}
Claude MUST complete these (requires judgment):
- [ ] Applied tracking: Which collaboration patterns from collaboration.md are relevant to today's task? Write to today's journal.
- [ ] Duplicate detection: Any semantically similar entries in collaboration.md? Flag to user.

Do NOT skip these. Do NOT defer. Complete before addressing user's message."
fi

# --- Output ---
full_context="${statusline_output:+${statusline_output}$'\n\n'}${repair_report:+${repair_report}$'\n\n'}${synthesis_directive:+${synthesis_directive}$'\n\n'}${skill_content}${missed_close}${health_warning}${proposal_summary}${social_warnings:+$'\n\n'${social_warnings}}${sensory_output:+$'\n\n'Sensory scan:$'\n'${sensory_output}}${carry_over_msg}"
escaped=$(escape_for_json "$full_context")
context="<cortex-session-start>${escaped}</cortex-session-start>"

cat <<EOF
{
  "additional_context": "${context}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${context}"
  }
}
EOF
exit 0
